# GitHub personal access token — needs pull_requests:write and repo:read scopes
GITHUB_TOKEN=ghp_your_token_here

# LLM provider: "openai" (default), "anthropic", or "ollama" (local, no API cost)
LLM_PROVIDER=openai

# OpenAI — used when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your_key_here
OPENAI_MODEL=gpt-4o

# Anthropic — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama — used when LLM_PROVIDER=ollama (must be pulled: ollama pull qwen2.5-coder:7b)
OLLAMA_MODEL=qwen2.5-coder:7b

# Path to the SQLite database (created automatically on first run)
DB_PATH=pr_reviewer.db
